
{
  "entities": {
    "user": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string",
          "description": "The user's display name"
        },
        "email": {
          "type": "string",
          "description": "The user's email address"
        },
        "photoURL": {
          "type": "string",
          "description": "The URL of the user's profile picture"
        },
        "lastLogin": {
          "type": "string",
          "format": "date-time",
          "description": "The last time the user logged in"
        },
        "balance": {
          "type": "number",
          "description": "The user's account balance"
        },
        "ipAddress": {
          "type": "string",
          "description": "The user's registered IP address"
        },
        "country": {
          "type": "string"
        }
      },
      "required": ["displayName", "email"]
    },
    "submission": {
      "title": "Submission",
      "description": "An IMEI submission for checking",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who made the submission"
        },
        "model": {
          "type": "string",
          "description": "The device model"
        },
        "price": {
          "type": "number",
          "description": "The price for the unlock service"
        },
        "image": {
          "type": "string",
          "description": "URL of the device image"
        },
        "imei": {
          "type": "string",
          "description": "The IMEI or serial number of the device"
        },
        "status": {
          "type": "string",
          "enum": ["waiting", "feedback", "paid", "eligible", "not_supported", "find_my_off", "device_found", "chimaera", "banned"],
          "description": "The current status of the submission"
        },
        "icloudStatus": {
          "type": "string",
          "enum": ["clean", "lost"],
          "description": "The iCloud status determined by admin"
        },
        "successRate": {
          "type": "number",
          "description": "The probability percentage of a successful unlock"
        },
        "feedback": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ipAddress": {
          "type": "string",
          "description": "The IP address from which the submission was made"
        },
        "country": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["userId", "model", "price", "imei", "status", "createdAt"]
    },
    "activity": {
      "title": "User Activity",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "ipAddress": { "type": "string" },
        "country": { "type": "string" },
        "action": { "type": "string" },
        "path": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "notification": {
      "title": "Notification",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Specific user ID or 'all'" },
        "message": { "type": "string" },
        "link": { "type": "string", "description": "Optional clickable link" },
        "createdAt": { "type": "string", "format": "date-time" },
        "readBy": { "type": "array", "items": { "type": "string" } }
      }
    },
    "withdrawal": {
      "title": "Withdrawal Request",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processed", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "banned_user": {
      "title": "Banned User",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "banned_ip": {
      "title": "Banned IP",
      "type": "object",
      "properties": {
        "ip": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "past_work": {
      "title": "Past Work Entry",
      "description": "Showcase of completed unlock services",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "completionDate": { "type": "string", "format": "date" },
        "imageUrls": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "completionDate", "imageUrls"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/user" },
      "description": "User profile"
    },
    "/submissions/{submissionId}": {
      "schema": { "$ref": "#/backend/entities/submission" },
      "description": "Device check submissions"
    },
    "/activities/{activityId}": {
      "schema": { "$ref": "#/backend/entities/activity" },
      "description": "User audit log"
    },
    "/notifications/{notificationId}": {
      "schema": { "$ref": "#/backend/entities/notification" },
      "description": "System notifications"
    },
    "/withdrawals/{requestId}": {
      "schema": { "$ref": "#/backend/entities/withdrawal" },
      "description": "User withdrawal requests"
    },
    "/banned_users/{userId}": {
      "schema": { "$ref": "#/backend/entities/banned_user" },
      "description": "Blacklisted user IDs"
    },
    "/banned_ips/{ipId}": {
      "schema": { "$ref": "#/backend/entities/banned_ip" },
      "description": "Blacklisted IP addresses"
    },
    "/past_work/{workId}": {
      "schema": { "$ref": "#/backend/entities/past_work" },
      "description": "Gallery of successful unlocks and reviews"
    }
  }
}
